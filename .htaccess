# Laravel Backend .htaccess
# Redirect all requests to public folder

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Prevent access to sensitive files
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<FilesMatch "composer\.(json|lock)">
    Require all denied
</FilesMatch>

# Prevent directory listing
Options -Indexes
